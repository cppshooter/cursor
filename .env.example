# ===== MySQL 连接配置 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=your_database
DB_CHARSET=utf8mb4

# 连接池
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10

# ===== 认证：固定 KEY =====
# 客户端请求头需携带：X-API-Key: <API_KEY>
API_KEY=please-change-this-key
API_KEY_HEADER=X-API-Key

# ===== 业务 / 分页 =====
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# 查询过滤条件（与给定 SQL 保持一致，可按需调整）
APPLY_STATUS=check_doing
CREATE_TIME_AFTER=2024-05-31 00:00:00

# 建设简介内容列名（给定 SQL 未含该列）。
# 若库表中存在该列（如 content / remark / build_content），填入列名即可纳入查询；
# 留空则该字段返回 null。
BRIEF_COLUMN=

# ===== 服务 =====
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
